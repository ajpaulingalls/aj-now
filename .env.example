DATABASE_URL=postgres://aj:aj@localhost:5432/aj_now
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=devkey
S3_SECRET_KEY=devsecret
S3_BUCKET=aj-now-media
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Host-side port mappings for `infra/docker-compose.yml`. Override these
# if your machine already runs Postgres on 5432 or anything on 9000/9001.
# When you override HOST_PG_PORT, also bump the port in DATABASE_URL.
# HOST_PG_PORT=5433
# HOST_S3_PORT=9100
# HOST_S3_CONSOLE_PORT=9101
