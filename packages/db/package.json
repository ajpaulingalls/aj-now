{
  "name": "@aj-now/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./zod": "./src/zod.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint .",
    "test": "bunx vitest run",
    "migrate": "bun run src/migrate.ts",
    "generate": "bunx drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aj-now/config": "workspace:*",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.1",
    "testcontainers": "^10.13.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
